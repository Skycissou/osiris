# ═══════════════════════════════════════════════════════════════════════════
#  OSIRIS V4 LEAN — Environment Template
#  Copier ce fichier en `.env.local` puis renseigner les valeurs.
# ═══════════════════════════════════════════════════════════════════════════

# URL de base du backend FastAPI FR (EXTERNE à ce repo). Toutes les données
# OSINT françaises viennent de là ; le front ne fait que des appels sortants
# (login à cookie → credentials: 'include'). Sans valeur, aucune couche FR ne
# se charge (la carte reste fonctionnelle).
#   Exemple : https://api.osiris.cissouhub.cloud
NEXT_PUBLIC_API_BASE=

# Port hôte de publication de l'UI (le conteneur écoute toujours sur 3000).
OSIRIS_PORT=3000

# ═══════════════════════════════════════════════════════════════════════════
#  COUCHES TEMPS RÉEL (ShadowBroker parity) — clés à renseigner pour activer.
#  TOUT dégrade en douceur : sans clé, la couche reste vide (jamais d'erreur).
#  Détail complet : docs/SHADOWBROKER-PARITY.md
# ═══════════════════════════════════════════════════════════════════════════

# ── Fonctionnent SANS clé (déjà actifs) ──
#   Avions (adsb.lol) · Séismes (USGS) · Satellites (celestrak+SGP4) ·
#   Bases militaires (OpenStreetMap/Overpass). Rien à renseigner.

# ── Feux NASA FIRMS (gratuit sur inscription) ──
FIRMS_MAP_KEY=

# ── Navires AIS (payant/clé) ──
#   aisstream.io est en WebSocket (non pollable) → fournir plutôt une source REST :
AIS_REST_URL=            # gabarit : https://source-ais/vessels?key={KEY}&bbox={MINLNG},{MINLAT},{MAXLNG},{MAXLAT}
AIS_REST_KEY=

# ── Couches SENSIBLES (forme 2 — enquêteur, opt-in + consentement, cadre ARPD) ──
#   Visibles seulement si NEXT_PUBLIC_OSIRIS_FORM=2. Sans clé → couche vide.
CCTV_SOURCE_KEY=         # 🔴 caméras publiques (flux in-app) — LIGNE ROUGE, usage veille strict
GPSJAM_KEY=              # brouillage GPS
SCANNER_KEY=             # scanners radio
SIGINT_KEY=              # mesh / APRS
FRONTLINE_KEY=           # lignes de front
TELEGRAM_OSINT_KEY=      # signaux Telegram géolocalisés

# ── Forme de l'app ──
#   1 = tout public (ARPD, défaut) · 2 = perso enquêteur (débloque les couches sensibles)
NEXT_PUBLIC_OSIRIS_FORM=1
