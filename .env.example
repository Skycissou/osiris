# ═══════════════════════════════════════════════════════════════════════════
#  OSIRIS V4 LEAN — Environment Template
#  Copier ce fichier en `.env.local` puis renseigner les valeurs.
# ═══════════════════════════════════════════════════════════════════════════

# URL de base du backend FastAPI FR (EXTERNE à ce repo). Toutes les données
# OSINT françaises viennent de là ; le front ne fait que des appels sortants
# (login à cookie → credentials: 'include'). Sans valeur, aucune couche FR ne
# se charge (la carte reste fonctionnelle).
#   Exemple : https://api.osiris.cissouhub.cloud
NEXT_PUBLIC_API_BASE=

# Port hôte de publication de l'UI (le conteneur écoute toujours sur 3000).
OSIRIS_PORT=3000
